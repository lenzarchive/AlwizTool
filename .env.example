# Server
PORT=3000
NODE_ENV=production

# Site
SITE_URL=https://your-domain.com

# CORS (production only)
CORS_ORIGIN=https://your-domain.com

# Ads (set ADS_ENABLED=true untuk mengaktifkan)
ADS_ENABLED=false
ADS_ZONE_728=your_zone_key_here
ADS_ZONE_300=your_zone_key_here
ADS_ZONE_NATIVE=your_native_zone_key_here
# Native ad script URL penuh dari effectivegatecpm.com (dari dashboard Adsterra)
ADS_ZONE_NATIVE_SCRIPT=https://plXXXXXXXX.effectivegatecpm.com/your_native_zone_key_here/invoke.js
