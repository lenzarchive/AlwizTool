{
  "name": "alwiztool",
  "version": "1.0.0",
  "description": "All-in-one developer & utility tools by AlwizBA",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"npm run watch:css\"",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/css/input.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "open-graph-scraper": "^6.7.3",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
