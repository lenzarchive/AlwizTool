<footer class="mt-auto border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center mb-2">
          <picture class="logo-light">
            <source srcset="/logo_dark.webp" type="image/webp">
            <img src="/logo_dark.png" class="h-12 w-auto" width="199" height="108" alt="AlwizTool Logo">
          </picture>
          <picture class="logo-dark">
            <source srcset="/logo_light.webp" type="image/webp">
            <img src="/logo_light.png" class="h-12 w-auto" width="199" height="108" alt="AlwizTool Logo">
          </picture>
        </div>
        <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= t.footer.tagline %></p>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-3"><%= t.footer.tools %></p>
        <ul class="space-y-1.5">
          <% if (typeof tools !== 'undefined') { tools.slice(0, 6).forEach(function(tool) { %>
          <li>
            <a href="/tools/<%= tool.slug %>" class="text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
              <%= t.tools[tool.i18nKey] ? t.tools[tool.i18nKey].name : tool.name %>
            </a>
          </li>
          <% }) } %>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-3"><%= t.footer.socials %></p>
        <div class="flex flex-col gap-2 mb-4">
          <a href="https://tiktok.com/@alwizba" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.28 8.28 0 004.84 1.55V6.79a4.84 4.84 0 01-1.07-.1z"/></svg>
            TikTok @alwizba
          </a>
          <a href="https://instagram.com/alwiz.ba" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            Instagram @alwiz.ba
          </a>
          <a href="https://facebook.com/alwizba" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            Facebook @alwizba
          </a>
        </div>
        <p class="text-xs font-semibold text-slate-900 dark:text-slate-100 mb-2"><%= t.footer.support %></p>
        <div class="flex gap-2 flex-wrap">
          <a href="https://saweria.co/alwizba" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-3 py-1.5 bg-orange-50 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400 text-xs font-medium rounded-lg hover:bg-orange-100 dark:hover:bg-orange-900/40 transition-colors border border-orange-200 dark:border-orange-800">
            <%= t.footer.supportID %>
          </a>
          <a href="https://ko-fi.com/alwizba" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-3 py-1.5 bg-sky-50 dark:bg-sky-900/20 text-sky-600 dark:text-sky-400 text-xs font-medium rounded-lg hover:bg-sky-100 dark:hover:bg-sky-900/40 transition-colors border border-sky-200 dark:border-sky-800">
            <%= t.footer.supportIntl %>
          </a>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-slate-400">© <%= new Date().getFullYear() %> AlwizTool by AlwizBA. <%= t.footer.rights %></p>
      <p class="text-xs text-slate-400"><a href="https://alwiztool.work.gd" class="hover:text-indigo-600 transition-colors">alwiztool.work.gd</a></p>
    </div>
  </div>
</footer>
