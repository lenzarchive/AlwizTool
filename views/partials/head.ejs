<!DOCTYPE html>
<html lang="<%= lang %>" class="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="author" content="AlwizBA">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= canonical %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:url" content="<%= canonical %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="AlwizTool">
  <meta property="og:image" content="<%= (process.env.SITE_URL || 'https://alwiztool.work.gd') %>/og-image.png">
  <meta property="og:locale" content="<%= lang === 'id' ? 'id_ID' : 'en_US' %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">
  <meta name="twitter:image" content="<%= (process.env.SITE_URL || 'https://alwiztool.work.gd') %>/og-image.png">
  <link rel="alternate" hreflang="en" href="<%= canonical %>?lang=en">
  <link rel="alternate" hreflang="id" href="<%= canonical %>?lang=id">
  <link rel="alternate" hreflang="x-default" href="<%= canonical %>">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="preload" as="font" type="font/woff2" href="/fonts/v2/inter-500.woff2" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="/fonts/v2/inter-700.woff2" crossorigin>
  <link rel="preload" as="style" href="/css/style.css" id="mainCss">
  <noscript><link rel="stylesheet" href="/css/style.css"></noscript>
  <link rel="preload" as="image" href="/logo_dark.webp" type="image/webp">
  <style>
    *,::before,::after{box-sizing:border-box}
    body{margin:0;font-family:Inter,system-ui,sans-serif;background:#f8fafc;color:#0f172a;min-height:100vh;display:flex;flex-direction:column;overflow-x:hidden}
    html.dark body{background:#020617;color:#f8fafc}
    main{flex:1 1 0%;min-height:0}
    header{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.9);border-bottom:1px solid #e2e8f0;-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px)}
    html.dark header{background:rgba(2,6,23,.9);border-bottom-color:#1e293b}
    header>div{max-width:72rem;margin:0 auto;padding:0 1rem;height:3.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem}
    header img{height:3rem;width:auto;aspect-ratio:199/108}
    .logo-dark{display:none}.logo-light{display:block}
    html.dark .logo-dark{display:block}html.dark .logo-light{display:none}
    main>section:first-child{max-width:72rem;margin:0 auto;padding:3rem 1rem;text-align:center}
    .tool-category{margin-bottom:2.5rem}
    .tool-category>.grid{display:grid;grid-template-columns:repeat(1,minmax(0,1fr));gap:.75rem}
    @media(min-width:640px){.tool-category>.grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
    @media(min-width:1024px){.tool-category>.grid{grid-template-columns:repeat(3,minmax(0,1fr))}}
  </style>
  <script nonce="<%= nonce %>">(function() {
      var saved = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (!saved && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
      var css = document.getElementById('mainCss');
      if (css) {
        css.addEventListener('load', function() { this.rel = 'stylesheet'; });
      }
    })();
</script>
  <script type="application/ld+json" nonce="<%= nonce %>">{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AlwizTool",
    "url": "<%= process.env.SITE_URL || 'https://alwiztool.work.gd' %>",
    "description": "All-in-one developer and utility tools",
    "author": { "@type": "Person", "name": "AlwizBA" },
    "inLanguage": ["en", "id"]
  }
</script>
</head>
