<% var tl = t.tools.regex; var tc = t.common; %>
<%- include('../partials/head') %>
<body class="bg-slate-50 dark:bg-slate-950 min-h-screen flex flex-col">
<%- include('../partials/header') %>
<main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
  <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6">
    <a href="/" class="hover:text-indigo-600 transition-colors"><%= tc.back %></a>
    <span>/</span>
    <span class="text-slate-600 dark:text-slate-300"><%= tl.title %></span>
  </nav>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1"><%= tl.title %></h1>
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= tl.subtitle %></p>
  </div>
  <%- include('../partials/ads', { adType: 'banner728' }) %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Left: Pattern + Test string -->
    <div class="space-y-4">
      <div class="card p-5 space-y-3">
        <label class="label"><%= tl.patternLabel %></label>
        <div class="flex items-center gap-1">
          <span class="text-slate-400 font-mono text-lg shrink-0 select-none">/</span>
          <input type="text" id="regexPattern" class="input-field font-mono flex-1" placeholder="<%= tl.patternPlaceholder %>" autocomplete="off" spellcheck="false">
          <span class="text-slate-400 font-mono text-lg shrink-0 select-none">/</span>
          <input type="text" id="regexFlagsInput" class="input-field font-mono w-16 text-center" value="g" maxlength="6" spellcheck="false" placeholder="gim">
        </div>
        <div id="regexError" class="hidden text-xs text-red-500 font-medium px-1"></div>
        <div class="flex flex-wrap gap-2 pt-1">
          <% [['g','global'],['i','case insensitive'],['m','multiline'],['s','dotAll']].forEach(function(f) { %>
          <label class="flex items-center gap-1.5 cursor-pointer px-2.5 py-1 rounded-lg border border-slate-200 dark:border-slate-700 text-xs hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors select-none">
            <input type="checkbox" class="flag-check accent-indigo-600" data-flag="<%= f[0] %>" <%= f[0]==='g' ? 'checked' : '' %>>
            <span class="font-mono font-semibold text-slate-700 dark:text-slate-200"><%= f[0] %></span>
            <span class="text-slate-400 dark:text-slate-500"><%= f[1] %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="card p-5 space-y-3">
        <label class="label" for="testString"><%= tl.testLabel %></label>
        <textarea id="testString" class="textarea-field min-h-[200px] leading-relaxed" placeholder="<%= tl.testPlaceholder %>" spellcheck="false"></textarea>
      </div>
    </div>

    <!-- Right: Highlighted + matches -->
    <div class="space-y-4">
      <div class="card p-5 space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tl.matchesLabel %></h2>
          <span id="matchCount" class="text-xs font-mono text-slate-400"></span>
        </div>
        <div id="highlightedText" class="result-box min-h-[100px] text-sm leading-relaxed whitespace-pre-wrap font-mono"></div>
      </div>

      <div class="card p-5 space-y-3">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tl.groupsLabel %></h2>
        <div id="matchList" class="space-y-2 max-h-64 overflow-y-auto"></div>
        <p id="noMatchMsg" class="text-sm text-slate-400 italic hidden"><%= tl.noMatches %></p>
      </div>
    </div>
  </div>

  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
</main>
<%- include('../partials/footer') %>
<script>var I18N = {
  noMatches: "<%= tl.noMatches %>",
  matchCount: "<%= tl.matchCount %>",
  matchCountPlural: "<%= tl.matchCountPlural %>",
  invalidRegex: "<%= tl.invalidRegex %>",
  noGroups: "<%= tl.noGroups %>",
  copied: "<%= tc.copied %>"
};</script>
<script src="/js/app.js"></script>
<script src="/js/modules/regex.js"></script>
</body>
</html>
