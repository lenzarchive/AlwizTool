<% var tl = t.tools.qrcode; var tc = t.common; %>
<%- include('../partials/head') %>
<body class="bg-slate-50 dark:bg-slate-950 min-h-screen flex flex-col">
<%- include('../partials/header') %>
<main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
  <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6">
    <a href="/" class="hover:text-indigo-600 transition-colors"><%= tc.back %></a>
    <span>/</span>
    <span class="text-slate-600 dark:text-slate-300"><%= tl.title %></span>
  </nav>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1"><%= tl.title %></h1>
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= tl.subtitle %></p>
  </div>
  <%- include('../partials/ads', { adType: 'banner728' }) %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.input %></h2>
      <textarea id="inputText" class="textarea-field min-h-[140px]" placeholder="<%= tl.inputPlaceholder %>"></textarea>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="label" for="sizeInput"><%= tl.sizeLabel %></label>
          <input type="number" id="sizeInput" value="300" min="100" max="800" step="50" class="input-field">
        </div>
        <div>
          <label class="label" for="formatSelect"><%= tl.formatLabel %></label>
          <select id="formatSelect" class="select-field w-full">
            <option value="png">PNG</option>
            <option value="svg">SVG</option>
          </select>
        </div>
      </div>
      <button id="btnGenerate" class="btn-primary w-full justify-center"><%= tl.generateBtn %></button>
    </div>
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.result %></h2>
        <div class="flex gap-2">
          <button id="btnCopyImg" class="copy-btn"><%= tl.copyImage %></button>
          <button id="btnDownload" class="copy-btn"><%= tc.download %></button>
        </div>
      </div>
      <div id="qrPlaceholder" class="min-h-[240px] flex items-center justify-center text-slate-400 text-sm bg-slate-50 dark:bg-slate-800/50 rounded-xl border-2 border-dashed border-slate-200 dark:border-slate-700">
        <%= tl.placeholder %>
      </div>
      <div id="qrResult" class="hidden flex justify-center items-center min-h-[240px]"></div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
<script>var I18N = { pngOnly: "<%= tl.pngOnly %>", copied: "<%= tc.copied %>" };</script>
<script src="/js/app.js"></script>
<script src="/js/modules/qrcode.js"></script>
</body>
</html>
