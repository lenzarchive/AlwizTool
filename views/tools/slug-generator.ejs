<% var tl = t.tools.slugGenerator; var tc = t.common; %>
<div class="max-w-2xl mx-auto space-y-6">
  <div class="card p-5 space-y-4">
    <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.input %></h2>
    <textarea id="inputText" class="textarea-field min-h-[120px]" placeholder="<%= tl.inputPlaceholder %>"></textarea>
    <div class="flex flex-wrap gap-4 items-center">
      <div class="flex items-center gap-2">
        <label class="text-xs text-slate-500" for="separatorSelect"><%= tl.separator %>:</label>
        <select id="separatorSelect" class="select-field text-xs py-1.5 w-auto">
          <option value="-">Hyphen (-)</option>
          <option value="_">Underscore (_)</option>
          <option value=".">Dot (.)</option>
        </select>
      </div>
      <label class="flex items-center gap-2 text-xs text-slate-500 cursor-pointer">
        <input type="checkbox" id="lowercaseCheck" checked> <%= tl.lowercase %>
      </label>
    </div>
  </div>
  <div class="card p-5 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.output %></h2>
      <div class="flex gap-2 items-center">
        <span id="charCount" class="text-xs text-slate-400"></span>
        <span id="wordCount" class="text-xs text-slate-400"></span>
        <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
        <button id="btnClear" class="btn-secondary text-xs"><%= tc.clear %></button>
      </div>
    </div>
    <input id="outputText" type="text" class="result-box w-full font-mono text-sm" readonly placeholder="...">
  </div>
</div>
<div class="mt-6 card p-5">
  <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
</div>
<script nonce="<%= nonce %>">var I18N = {
  nothingToCopy: "<%= tc.nothingToCopy %>",
  copied: "<%= tc.copied %>"
};
</script>
<script nonce="<%= nonce %>" src="/js/app.js"></script>
<script nonce="<%= nonce %>" src="/js/modules/slug-generator.js"></script>
