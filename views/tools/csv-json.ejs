<% var tl = t.tools.csvJson; var tc = t.common; %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.input %></h2>
      <textarea id="inputText" class="textarea-field font-mono min-h-[300px]" placeholder="<%= tl.inputPlaceholder %>"></textarea>
      <div class="flex items-center gap-3 flex-wrap">
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500"><%= tl.modeLabel %>:</label>
          <select id="modeSelect" class="select-field text-xs py-1.5 w-auto">
            <option value="csv2json"><%= tl.modeCsvToJson %></option>
            <option value="json2csv"><%= tl.modeJsonToCsv %></option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500"><%= tl.delimiterLabel %>:</label>
          <select id="delimiterSelect" class="select-field text-xs py-1.5 w-auto">
            <option value=","   ><%= tl.delimiterComma %></option>
            <option value=";"   ><%= tl.delimiterSemicolon %></option>
            <option value="\t"  ><%= tl.delimiterTab %></option>
            <option value="|"   ><%= tl.delimiterPipe %></option>
          </select>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="prettyPrint" class="accent-indigo-600" checked>
          <span class="text-xs text-slate-600 dark:text-slate-400"><%= tl.prettyPrint %></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="includeHeader" class="accent-indigo-600" checked>
          <span class="text-xs text-slate-600 dark:text-slate-400"><%= tl.includeHeader %></span>
        </label>
      </div>
      <div class="flex gap-2">
        <button id="btnConvert" class="btn-primary flex-1"><%= tc.convert %></button>
        <button id="btnClear" class="btn-secondary"><%= tc.clear %></button>
      </div>
    </div>
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.output %></h2>
        <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
      </div>
      <textarea id="outputText" class="result-box font-mono min-h-[300px]" readonly placeholder="<%= tl.outputPlaceholder %>"></textarea>
      <div id="errorMsg" class="hidden text-xs text-rose-500"></div>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
<script nonce="<%= nonce %>">var I18N = { copied: "<%= tc.copied %>", nothingToCopy: "<%= tc.nothingToCopy %>" };
</script>
<script nonce="<%= nonce %>" src="/js/app.js">
</script>
<script nonce="<%= nonce %>" src="/js/modules/csv-json.js">
</script>
