<% var tl = t.tools.timestamp; var tc = t.common; %>
  <div class="card p-5 mb-6 border-indigo-200 dark:border-indigo-800 bg-indigo-50/50 dark:bg-indigo-900/10">
    <p class="text-xs font-medium uppercase tracking-wide text-indigo-400 mb-2"><%= tl.currentTime %></p>
    <div class="flex flex-wrap items-baseline gap-4">
      <div>
        <span class="text-xs text-slate-400 block mb-0.5"><%= tl.seconds %></span>
        <span id="currentSec" class="text-2xl font-bold font-mono text-indigo-600"></span>
      </div>
      <div>
        <span class="text-xs text-slate-400 block mb-0.5"><%= tl.milliseconds %></span>
        <span id="currentMs" class="text-2xl font-bold font-mono text-indigo-400"></span>
      </div>
      <div class="ml-auto text-right">
        <span class="text-xs text-slate-400 block mb-0.5">ISO 8601</span>
        <span id="currentISO" class="text-sm font-mono text-slate-600 dark:text-slate-300"></span>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tl.tsToDate %></h2>
      <input type="number" id="tsInput" class="input-field font-mono" placeholder="<%= tl.tsPlaceholder %>">
      <div class="flex gap-2">
        <button id="btnConvertTS" class="btn-primary"><%= tl.convertBtn %></button>
        <button id="btnUseNow" class="btn-secondary"><%= tl.useNow %></button>
      </div>
      <div id="tsResult" class="space-y-2 hidden">
        <% [['UTC','UTC'],['Local','Local'],['ISO8601','ISO 8601'],['RFC2822','RFC 2822']].forEach(function(row) { %>
        <div class="flex items-center gap-2 p-2.5 bg-slate-50 dark:bg-slate-800/60 rounded-lg">
          <span class="text-xs text-slate-500 font-medium w-20 shrink-0"><%= row[1] %></span>
          <span id="ts-<%= row[0] %>" class="text-xs font-mono text-slate-900 dark:text-slate-100 flex-1 min-w-0 truncate"></span>
          <button class="copy-btn shrink-0 copy-ts-btn" data-target="ts-<%= row[0] %>"><%= tc.copy %></button>
        </div>
        <% }) %>
      </div>
    </div>
    <div class="card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tl.dateToTs %></h2>
      <input type="datetime-local" id="dateInput" class="input-field">
      <button id="btnConvertDate" class="btn-primary"><%= tl.convertBtn %></button>
      <div id="dateResult" class="space-y-2 hidden">
        <div class="flex items-center justify-between p-2.5 bg-slate-50 dark:bg-slate-800/60 rounded-lg">
          <span class="text-xs text-slate-500 font-medium"><%= tl.seconds %></span>
          <div class="flex items-center gap-2">
            <span id="date-seconds" class="text-sm font-mono font-bold text-slate-900 dark:text-slate-100"></span>
            <button class="copy-btn copy-ts-btn" data-target="date-seconds"><%= tc.copy %></button>
          </div>
        </div>
        <div class="flex items-center justify-between p-2.5 bg-slate-50 dark:bg-slate-800/60 rounded-lg">
          <span class="text-xs text-slate-500 font-medium"><%= tl.milliseconds %></span>
          <div class="flex items-center gap-2">
            <span id="date-ms" class="text-sm font-mono font-bold text-slate-900 dark:text-slate-100"></span>
            <button class="copy-ts-btn copy-btn" data-target="date-ms"><%= tc.copy %></button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
<script nonce="<%= nonce %>">var I18N = { invalidTs: "<%= tl.invalidTs %>", pickDate: "<%= tl.pickDate %>", copied: "<%= tc.copied %>" };
</script>
<script nonce="<%= nonce %>" src="/js/app.js">
</script>
<script nonce="<%= nonce %>" src="/js/modules/timestamp.js">
</script>
