<% var tl = t.tools.uuid; var tc = t.common; %>
  <div class="card p-5 mb-5">
    <div class="grid grid-cols-2 sm:flex sm:items-center gap-3 sm:gap-4 sm:flex-wrap">
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide" for="countInput"><%= tl.count %></label>
        <input type="number" id="countInput" value="10" min="1" max="100" class="input-field w-full text-center">
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide" for="formatSelect"><%= tl.formatLabel %></label>
        <select id="formatSelect" class="select-field w-full">
          <option value="lowercase"><%= tl.lowercase %></option>
          <option value="uppercase"><%= tl.uppercase %></option>
          <option value="noHyphen"><%= tl.noHyphen %></option>
          <option value="braces"><%= tl.braces %></option>
        </select>
      </div>
      <div class="flex gap-2 col-span-2 sm:col-span-1">
        <button id="btnGenerate" class="btn-primary flex-1 sm:flex-none"><%= tc.generate %></button>
        <button id="btnCopyAll" class="btn-secondary flex-1 sm:flex-none sm:ml-auto"><%= tc.copyAll %></button>
      </div>
    </div>
  </div>
  <div class="card p-5">
    <div id="uuidList" class="space-y-1.5 font-mono text-sm"></div>
  </div>
<script>var I18N = { generateFirst: "<%= tc.generateFirst %>", copied: "<%= tc.copied %>" };
</script>
<script src="/js/app.js">
</script>
<script src="/js/modules/uuid.js">
</script>
