<% var tl = t.tools.cspBuilder; var tc = t.common; %>
<div class="space-y-6">

  <!-- Directives Card -->
  <div class="card p-6">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-base"><%= tl.directives %></h2>
      <div class="flex gap-2">
        <button id="btnPresetStrict" class="btn-secondary text-xs px-3 py-1.5"><%= tl.presetStrict %></button>
        <button id="btnReset" class="btn-secondary text-xs px-3 py-1.5"><%= tc.clear %></button>
      </div>
    </div>

    <div class="space-y-1">
      <%
      var directives = [
        {key:'defaultSrc',name:'default-src'},{key:'scriptSrc',name:'script-src'},
        {key:'styleSrc',name:'style-src'},{key:'imgSrc',name:'img-src'},
        {key:'fontSrc',name:'font-src'},{key:'connectSrc',name:'connect-src'},
        {key:'objectSrc',name:'object-src'},{key:'frameSrc',name:'frame-src'},
        {key:'formAction',name:'form-action'},{key:'frameAncestors',name:'frame-ancestors'},
        {key:'baseUri',name:'base-uri'}
      ];
      directives.forEach(function(dir) { %>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 py-3 border-b border-slate-100 dark:border-slate-800 last:border-0">
        <span class="font-mono text-sm font-semibold text-indigo-600 dark:text-indigo-400 w-44 shrink-0"><%= dir.name %></span>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
          <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
            <input type="checkbox" class="dir-input w-4 h-4 rounded accent-indigo-600" data-key="<%= dir.key %>" value="'self'"> 'self'
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
            <input type="checkbox" class="dir-input w-4 h-4 rounded accent-indigo-600" data-key="<%= dir.key %>" value="'none'"> 'none'
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
            <input type="checkbox" class="dir-input w-4 h-4 rounded accent-indigo-600" data-key="<%= dir.key %>" value="*"> *
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
            <input type="checkbox" class="dir-input w-4 h-4 rounded accent-indigo-600" data-key="<%= dir.key %>" value="'unsafe-inline'"> 'unsafe-inline'
          </label>
          <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
            <input type="checkbox" class="dir-input w-4 h-4 rounded accent-indigo-600" data-key="<%= dir.key %>" value="data:"> data:
          </label>
          <input type="text" class="dir-input input-field text-sm py-1.5 w-52" data-key="<%= dir.key %>" placeholder="https://example.com">
        </div>
      </div>
      <% }); %>

      <!-- Extra flags -->
      <div class="flex flex-wrap gap-6 pt-4">
        <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
          <input type="checkbox" id="upgradeInsecure" class="w-4 h-4 rounded accent-indigo-600"> upgrade-insecure-requests
        </label>
        <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors select-none">
          <input type="checkbox" id="blockMixed" class="w-4 h-4 rounded accent-indigo-600"> block-all-mixed-content
        </label>
      </div>
    </div>
  </div>

  <!-- Output Card -->
  <div class="card p-6 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-base"><%= tl.policyValue %></h2>
      <button id="btnCopyValue" class="copy-btn"><%= tc.copy %></button>
    </div>
    <textarea id="outputText" class="result-box min-h-[100px] font-mono text-sm leading-relaxed" readonly placeholder="..."></textarea>

    <div class="flex items-center justify-between pt-2">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-base"><%= tl.header %></h2>
      <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
    </div>
    <textarea id="headerOutput" class="result-box min-h-[80px] font-mono text-sm leading-relaxed" readonly placeholder="Content-Security-Policy: ..."></textarea>
  </div>

</div>

<!-- About section -->
<div class="mt-6 card p-6">
  <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
</div>

<script nonce="<%= nonce %>">var I18N = {
  nothingToCopy: "<%= tc.nothingToCopy %>",
  copied: "<%= tc.copied %>"
};
</script>
<script nonce="<%= nonce %>" src="/js/app.js"></script>
<script nonce="<%= nonce %>" src="/js/modules/csp-builder.js"></script>
