<% var tl = t.tools.chmod; var tc = t.common; %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-5">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm">Permissions</h2>
      <% [
        ['owner', tl.owner],
        ['group',  tl.group],
        ['others', tl.others]
      ].forEach(function(row) { %>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2"><%= row[1] %></p>
        <div class="grid grid-cols-3 gap-3">
          <% [['r','read',4],['w','write',2],['x','execute',1]].forEach(function(bit) { %>
          <label class="flex items-center gap-2 p-3 rounded-xl border border-slate-200 dark:border-slate-700 cursor-pointer hover:border-indigo-400 dark:hover:border-indigo-600 transition-colors has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50 dark:has-[:checked]:bg-indigo-900/20">
            <input type="checkbox" class="perm-bit accent-indigo-600" data-role="<%= row[0] %>" data-bit="<%= bit[2] %>">
            <div>
              <span class="block text-sm font-bold font-mono text-slate-700 dark:text-slate-300"><%= bit[0] %></span>
              <span class="block text-[10px] text-slate-400"><%= tl[bit[1]] || bit[1] %></span>
            </div>
          </label>
          <% }) %>
        </div>
      </div>
      <% }) %>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-2"><%= tl.specialBits %></p>
        <div class="grid grid-cols-3 gap-3">
          <% [['setuid',2048],['setgid',1024],['sticky',512]].forEach(function(sb) { %>
          <label class="flex items-center gap-2 p-3 rounded-xl border border-slate-200 dark:border-slate-700 cursor-pointer hover:border-amber-400 dark:hover:border-amber-600 transition-colors has-[:checked]:border-amber-500 has-[:checked]:bg-amber-50 dark:has-[:checked]:bg-amber-900/20">
            <input type="checkbox" class="special-bit accent-amber-600" data-bit="<%= sb[1] %>">
            <span class="text-xs font-mono font-bold text-slate-700 dark:text-slate-300"><%= tl[sb[0]] || sb[0] %></span>
          </label>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="space-y-4">
      <div class="card p-5 space-y-3">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.result %></h2>
        <div class="flex gap-4">
          <div class="flex-1">
            <label class="text-xs text-slate-500 mb-1 block"><%= tl.numericLabel %></label>
            <input type="text" id="numericInput" class="input-field font-mono text-2xl font-bold text-center" placeholder="644" maxlength="4">
          </div>
          <div class="flex-1">
            <label class="text-xs text-slate-500 mb-1 block"><%= tl.symbolicLabel %></label>
            <input type="text" id="symbolicInput" class="input-field font-mono text-center" placeholder="rw-r--r--" maxlength="10" readonly>
          </div>
        </div>
      </div>
      <div class="card p-5 space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tl.commandLabel %></h2>
          <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
        </div>
        <div class="bg-slate-900 rounded-xl p-4 font-mono text-sm">
          <span class="text-slate-500">$ </span>
          <span id="chmodCommand" class="text-emerald-400">chmod 644 filename</span>
        </div>
      </div>
      <div class="card p-5">
        <div class="grid grid-cols-4 text-xs font-mono text-center gap-1">
          <div class="text-slate-400 font-semibold pb-2 col-span-1"></div>
          <div class="text-slate-400 font-semibold pb-2"><%= tl.read %></div>
          <div class="text-slate-400 font-semibold pb-2"><%= tl.write %></div>
          <div class="text-slate-400 font-semibold pb-2"><%= tl.execute %></div>
          <% [['owner',tl.owner],['group',tl.group],['others',tl.others]].forEach(function(r) { %>
          <div class="text-slate-500 py-1.5 text-left font-semibold"><%= r[1] %></div>
          <div id="vis-<%= r[0] %>-r" class="py-1.5 rounded font-bold"></div>
          <div id="vis-<%= r[0] %>-w" class="py-1.5 rounded font-bold"></div>
          <div id="vis-<%= r[0] %>-x" class="py-1.5 rounded font-bold"></div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
<script>var I18N = { copied: "<%= tc.copied %>" };
</script>
<script src="/js/app.js">
</script>
<script src="/js/modules/chmod.js">
</script>
