<% var tl = t.tools.stringEscape; var tc = t.common; %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.input %></h2>
      <textarea id="inputText" class="textarea-field min-h-[220px]" placeholder="<%= tl.inputPlaceholder %>"></textarea>
      <div class="flex items-center gap-3 flex-wrap">
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500"><%= tl.modeLabel %>:</label>
          <select id="modeSelect" class="select-field text-xs py-1.5 w-auto">
            <option value="escape"><%= tc.encode %></option>
            <option value="unescape"><%= tc.decode %></option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500"><%= tl.typeLabel %>:</label>
          <select id="typeSelect" class="select-field text-xs py-1.5 w-auto">
            <option value="js">JavaScript</option>
            <option value="json">JSON</option>
            <option value="html">HTML</option>
            <option value="sql">SQL</option>
            <option value="regex">RegEx</option>
            <option value="csv">CSV</option>
          </select>
        </div>
      </div>
      <div class="flex gap-2">
        <button id="btnConvert" class="btn-primary flex-1"><%= tc.convert %></button>
        <button id="btnSwap" class="btn-secondary"><%= tc.swapLabel %></button>
        <button id="btnClear" class="btn-secondary"><%= tc.clear %></button>
      </div>
    </div>
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.output %></h2>
        <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
      </div>
      <textarea id="outputText" class="result-box min-h-[220px]" readonly placeholder="<%= tl.outputPlaceholder %>"></textarea>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
<script>var I18N = { copied: "<%= tc.copied %>", nothingToCopy: "<%= tc.nothingToCopy %>" };
</script>
<script src="/js/app.js">
</script>
<script src="/js/modules/string-escape.js">
</script>
