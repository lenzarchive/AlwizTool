<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <nav class="flex items-center gap-2 text-xs text-muted mb-6">
    <a href="/" class="hover:text-secondary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <span class="text-secondary">QR Code Generator</span>
  </nav>
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="font-display text-2xl sm:text-3xl font-bold text-primary">QR Code Generator</h1>
      <span class="badge tag-generators">Generators</span>
    </div>
    <p class="text-secondary text-sm">Buat QR code dari teks atau URL. Download PNG gratis, tanpa watermark.</p>
  </div>
  <%- include('../partials/ad', { type: 'banner728' }) %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1 card space-y-4">
      <div>
        <label class="label">Teks / URL</label>
        <textarea id="qr-input" class="textarea-base h-28" placeholder="https://alwiztool.my.id atau teks apapun..."></textarea>
      </div>
      <div>
        <label class="label">Ukuran (px)</label>
        <select id="qr-size" class="input-base">
          <option value="200">200×200</option>
          <option value="300" selected>300×300</option>
          <option value="500">500×500</option>
          <option value="800">800×800</option>
        </select>
      </div>
      <div>
        <label class="label">Error Correction</label>
        <select id="qr-error" class="input-base">
          <option value="L">L — Low (7%)</option>
          <option value="M" selected>M — Medium (15%)</option>
          <option value="Q">Q — Quartile (25%)</option>
          <option value="H">H — High (30%)</option>
        </select>
      </div>
      <button id="btn-generate" class="btn-primary w-full">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        Generate QR Code
      </button>
    </div>

    <div class="lg:col-span-2 card flex flex-col items-center justify-center min-h-64 space-y-4">
      <div id="qr-placeholder" class="text-center text-muted">
        <svg class="w-16 h-16 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>
        </svg>
        <p class="text-sm">QR Code akan muncul di sini</p>
      </div>
      <div id="qr-result" class="hidden flex flex-col items-center gap-4">
        <img id="qr-image" src="" alt="QR Code" class="rounded-xl border-4 border-white" />
        <div class="flex gap-2">
          <a id="btn-download" href="#" download="qrcode.png" class="btn-primary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Download PNG
          </a>
        </div>
      </div>
      <div id="qr-loading" class="hidden text-accent">
        <div class="w-8 h-8 border-2 border-accent border-t-transparent rounded-full animate-spin"></div>
      </div>
    </div>
  </div>

  <section class="mt-10 pt-8 border-t border-border">
    <h2 class="section-title mb-4 text-base">Tools Lainnya</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% tools.filter(t => t.id !== 'qrcode').slice(0, 8).forEach(t => { %>
      <a href="<%= t.route %>" class="card-tool group text-left">
        <div class="text-xs font-semibold text-primary mb-1 group-hover:text-accent transition-colors"><%= t.name %></div>
        <div class="text-[11px] text-muted line-clamp-2"><%= t.description %></div>
      </a>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/tools/generators.js" defer></script>
