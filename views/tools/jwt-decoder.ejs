<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <nav class="flex items-center gap-2 text-xs text-muted mb-6">
    <a href="/" class="hover:text-secondary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <span class="text-secondary">JWT Decoder</span>
  </nav>
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="font-display text-2xl sm:text-3xl font-bold text-primary">JWT Decoder</h1>
      <span class="badge tag-security">Security</span>
    </div>
    <p class="text-secondary text-sm">Decode & inspect JSON Web Token. Header, payload, dan expiry ditampilkan dengan jelas.</p>
  </div>
  <%- include('../partials/ad', { type: 'banner728' }) %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card space-y-3">
      <label class="label">JWT Token</label>
      <textarea id="jwt-input" class="textarea-base h-40 font-mono text-xs" placeholder="Paste JWT token di sini... eyJhbGciOiJIUzI1NiIs..."></textarea>
      <button id="btn-decode" class="btn-primary w-full">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        Decode JWT
      </button>
      <div id="jwt-error" class="hidden text-xs text-error bg-error/10 border border-error/20 rounded-lg p-3"></div>
    </div>

    <div class="space-y-3">
      <div class="card space-y-3">
        <div class="flex items-center justify-between">
          <label class="label mb-0">Header</label>
          <span class="badge tag-security text-[10px]">Algorithm</span>
        </div>
        <pre id="jwt-header" class="code-block text-xs text-accent min-h-16 overflow-auto"><span class="text-muted">-</span></pre>
      </div>
      <div class="card space-y-3">
        <div class="flex items-center justify-between">
          <label class="label mb-0">Payload</label>
          <div id="jwt-expiry" class="text-xs text-muted"></div>
        </div>
        <pre id="jwt-payload" class="code-block text-xs text-accent min-h-24 overflow-auto"><span class="text-muted">-</span></pre>
      </div>
      <div class="card">
        <label class="label">Signature</label>
        <div id="jwt-signature" class="font-mono text-xs text-warning break-all text-muted">-</div>
      </div>
    </div>
  </div>

  <div class="mt-4 card">
    <p class="text-xs text-secondary leading-relaxed">⚠️ JWT decoder ini hanya mendecode token, bukan memverifikasi signature. Jangan paste token sensitif ke tool online manapun. Tool ini berjalan sepenuhnya di browser.</p>
  </div>

  <section class="mt-10 pt-8 border-t border-border">
    <h2 class="section-title mb-4 text-base">Tools Lainnya</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% tools.filter(t => t.id !== 'jwt').slice(0, 8).forEach(t => { %>
      <a href="<%= t.route %>" class="card-tool group text-left">
        <div class="text-xs font-semibold text-primary mb-1 group-hover:text-accent transition-colors"><%= t.name %></div>
        <div class="text-[11px] text-muted line-clamp-2"><%= t.description %></div>
      </a>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/tools/formatters.js" defer></script>
