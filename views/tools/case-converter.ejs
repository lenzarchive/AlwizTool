<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <nav class="flex items-center gap-2 text-xs text-muted mb-6">
    <a href="/" class="hover:text-secondary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <span class="text-secondary">Case Converter</span>
  </nav>
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="font-display text-2xl sm:text-3xl font-bold text-primary">Case Converter</h1>
      <span class="badge tag-text">Text</span>
    </div>
    <p class="text-secondary text-sm">Ubah teks ke camelCase, snake_case, PascalCase, UPPER, lower dan format lainnya.</p>
  </div>
  <%- include('../partials/ad', { type: 'banner728' }) %>

  <div class="card mb-4">
    <label class="label">Input Teks</label>
    <textarea id="case-input" class="textarea-base h-32" placeholder="Masukkan teks disini... contoh: hello world foo bar"></textarea>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <% const cases = [
      ['UPPER CASE', 'uppercase'],
      ['lower case', 'lowercase'],
      ['Title Case', 'titlecase'],
      ['Sentence case', 'sentencecase'],
      ['camelCase', 'camelcase'],
      ['PascalCase', 'pascalcase'],
      ['snake_case', 'snakecase'],
      ['kebab-case', 'kebabcase'],
      ['CONSTANT_CASE', 'constantcase'],
      ['dot.case', 'dotcase'],
      ['path/case', 'pathcase'],
      ['COBOL-CASE', 'cobolcase'],
    ]; %>
    <% cases.forEach(([label, id]) => { %>
    <div class="card space-y-2">
      <div class="flex items-center justify-between">
        <span class="text-xs font-medium text-secondary font-mono"><%= label %></span>
        <button class="copy-case btn-ghost text-xs py-0.5 px-2" data-id="<%= id %>">Copy</button>
      </div>
      <div id="<%= id %>" class="font-mono text-sm text-primary break-all min-h-6">-</div>
    </div>
    <% }) %>
  </div>

  <section class="mt-10 pt-8 border-t border-border">
    <h2 class="section-title mb-4 text-base">Tools Lainnya</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% tools.filter(t => t.id !== 'case-converter').slice(0, 8).forEach(t => { %>
      <a href="<%= t.route %>" class="card-tool group text-left">
        <div class="text-xs font-semibold text-primary mb-1 group-hover:text-accent transition-colors"><%= t.name %></div>
        <div class="text-[11px] text-muted line-clamp-2"><%= t.description %></div>
      </a>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/tools/text.js" defer></script>
