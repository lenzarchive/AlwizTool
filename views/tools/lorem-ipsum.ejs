<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <nav class="flex items-center gap-2 text-xs text-muted mb-6">
    <a href="/" class="hover:text-secondary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <span class="text-secondary">Lorem Ipsum</span>
  </nav>
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="font-display text-2xl sm:text-3xl font-bold text-primary">Lorem Ipsum Generator</h1>
      <span class="badge tag-generators">Generators</span>
    </div>
    <p class="text-secondary text-sm">Generate placeholder text untuk desain & layout dengan mudah.</p>
  </div>
  <%- include('../partials/ad', { type: 'banner728' }) %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1 card space-y-4">
      <div>
        <label class="label">Tipe</label>
        <select id="lorem-type" class="input-base">
          <option value="paragraphs">Paragraf</option>
          <option value="sentences">Kalimat</option>
          <option value="words">Kata</option>
        </select>
      </div>
      <div>
        <label class="label">Jumlah</label>
        <input type="number" id="lorem-count" value="3" min="1" max="100" class="input-base" />
      </div>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="start-lorem" checked class="accent-accent" />
        <span class="text-sm text-secondary">Mulai dengan "Lorem ipsum..."</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="html-format" class="accent-accent" />
        <span class="text-sm text-secondary">Output format HTML &lt;p&gt;</span>
      </label>
      <button id="btn-generate" class="btn-primary w-full">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><align-left></align-left><line x1="17" y1="10" x2="3" y2="10"></line><line x1="21" y1="6" x2="3" y2="6"></line><line x1="21" y1="14" x2="3" y2="14"></line><line x1="13" y1="18" x2="3" y2="18"></line></svg>
        Generate
      </button>
    </div>

    <div class="lg:col-span-2 card space-y-3">
      <div class="flex items-center justify-between">
        <label class="label mb-0">Result</label>
        <button id="btn-copy" class="btn-ghost text-xs py-1 px-2">Copy</button>
      </div>
      <textarea id="lorem-output" class="textarea-base h-72" readonly placeholder="Lorem ipsum akan muncul di sini..."></textarea>
    </div>
  </div>

  <section class="mt-10 pt-8 border-t border-border">
    <h2 class="section-title mb-4 text-base">Tools Lainnya</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% tools.filter(t => t.id !== 'lorem').slice(0, 8).forEach(t => { %>
      <a href="<%= t.route %>" class="card-tool group text-left">
        <div class="text-xs font-semibold text-primary mb-1 group-hover:text-accent transition-colors"><%= t.name %></div>
        <div class="text-[11px] text-muted line-clamp-2"><%= t.description %></div>
      </a>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/tools/generators.js" defer></script>
