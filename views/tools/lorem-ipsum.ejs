<% var tl = t.tools.loremIpsum; var tc = t.common; %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
    <div class="lg:col-span-2 card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.generate %></h2>
      <div>
        <label class="label"><%= tl.typeLabel %></label>
        <select id="typeSelect" class="select-field">
          <option value="paragraphs"><%= tl.typeParagraphs %></option>
          <option value="sentences"><%= tl.typeSentences %></option>
          <option value="words"><%= tl.typeWords %></option>
        </select>
      </div>
      <div>
        <label class="label" for="countInput"><%= tl.countLabel %></label>
        <input type="number" id="countInput" class="input-field" value="3" min="1" max="100">
      </div>
      <div class="space-y-2">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="startWithLorem" class="accent-indigo-600" checked>
          <span class="text-sm text-slate-600 dark:text-slate-400"><%= tl.startWithLorem %></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="htmlTags" class="accent-indigo-600">
          <span class="text-sm text-slate-600 dark:text-slate-400"><%= tl.htmlTags %></span>
        </label>
      </div>
      <button id="btnGenerate" class="btn-primary w-full"><%= tc.generate %></button>
    </div>
    <div class="lg:col-span-3 card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.result %></h2>
        <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
      </div>
      <textarea id="outputText" class="result-box min-h-[340px]" readonly></textarea>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
<script>var I18N = { copied: "<%= tc.copied %>", nothingToCopy: "<%= tc.nothingToCopy %>" };</script>
<script src="/js/app.js"></script>
<script src="/js/modules/lorem-ipsum.js"></script>
