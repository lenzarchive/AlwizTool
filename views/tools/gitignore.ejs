<% var tl = t.tools.gitignore; var tc = t.common; %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="card p-5 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tl.templates %></h2>
      <div class="flex gap-2">
        <button id="btnSelectAll" class="btn-secondary text-xs"><%= tl.selectAll %></button>
        <button id="btnClear" class="btn-secondary text-xs"><%= tc.clear %></button>
      </div>
    </div>
    <% var groups = [
      { label: 'Languages', items: [['node','Node.js'],['python','Python'],['java','Java'],['rust','Rust'],['go','Go'],['php','PHP']] },
      { label: 'Frameworks', items: [['react','React'],['vue','Vue.js'],['laravel','Laravel'],['django','Django']] },
      { label: 'IDE / Editor', items: [['vscode','VS Code'],['intellij','IntelliJ']] },
      { label: 'OS', items: [['macos','macOS'],['windows','Windows'],['linux','Linux']] },
      { label: 'Misc', items: [['dotenv','.env files'],['logs','Log files'],['docker','Docker']] }
    ]; %>
    <% groups.forEach(function(g) { %>
    <div>
      <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2"><%= g.label %></p>
      <div class="grid grid-cols-2 gap-y-1.5 gap-x-4">
        <% g.items.forEach(function(item) { %>
        <label class="flex items-center gap-2 text-xs text-slate-600 dark:text-slate-400 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400">
          <input type="checkbox" class="tmpl-check rounded" value="<%= item[0] %>">
          <%= item[1] %>
        </label>
        <% }); %>
      </div>
    </div>
    <% }); %>
  </div>
  <div class="card p-5 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm">.gitignore</h2>
      <div class="flex gap-2">
        <button id="btnCopy" class="copy-btn"><%= tc.copy %></button>
        <button id="btnDownload" class="btn-secondary text-xs"><%= tc.download %></button>
      </div>
    </div>
    <textarea id="outputText" class="result-box min-h-[400px] font-mono text-xs" readonly placeholder="<%= tl.placeholder %>"></textarea>
  </div>
</div>
<div class="mt-6 card p-5">
  <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
</div>
<script nonce="<%= nonce %>">var I18N = {
  nothingToCopy: "<%= tc.nothingToCopy %>",
  copied: "<%= tc.copied %>"
};
</script>
<script nonce="<%= nonce %>" src="/js/app.js"></script>
<script nonce="<%= nonce %>" src="/js/modules/gitignore.js"></script>
