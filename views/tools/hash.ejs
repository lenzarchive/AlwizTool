<% var tl = t.tools.hash; var tc = t.common; %>
<%- include('../partials/head') %>
<body class="bg-slate-50 dark:bg-slate-950 min-h-screen flex flex-col">
<%- include('../partials/header') %>
<main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
  <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6">
    <a href="/" class="hover:text-indigo-600 transition-colors"><%= tc.back %></a>
    <span>/</span>
    <span class="text-slate-600 dark:text-slate-300"><%= tl.title %></span>
  </nav>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1"><%= tl.title %></h1>
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= tl.subtitle %></p>
  </div>
  <%- include('../partials/ads', { adType: 'banner728' }) %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
    <div class="lg:col-span-2 card p-5 space-y-4">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.input %></h2>
      <textarea id="inputText" class="textarea-field min-h-[140px]" placeholder="<%= tl.inputPlaceholder %>"></textarea>
      <div class="flex gap-2">
        <button id="btnGenerate" class="btn-primary flex-1"><%= tc.generate %></button>
        <button id="btnClear" class="btn-secondary"><%= tc.clear %></button>
      </div>
      <div id="loadingIndicator" class="hidden text-xs text-slate-400"><%= tl.generating %></div>
    </div>
    <div class="lg:col-span-3 card p-5 space-y-3">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.result %></h2>
      <% ['md5', 'sha1', 'sha256', 'sha384', 'sha512'].forEach(function(algo) { %>
      <div class="space-y-1">
        <div class="flex items-center justify-between">
          <span class="text-xs font-semibold uppercase text-slate-400 dark:text-slate-500 tracking-wide"><%= algo.toUpperCase() %></span>
          <button class="copy-btn copy-hash-btn" data-algo="<%= algo %>"><%= tc.copy %></button>
        </div>
        <input id="hash-<%= algo %>" type="text" class="input-field font-mono text-xs" readonly placeholder="-">
      </div>
      <% }) %>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/modules/hash.js"></script>
</body>
</html>
