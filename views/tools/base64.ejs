<% var tl = t.tools.base64; var tc = t.common; %>
<%- include('../partials/head') %>
<body class="bg-slate-50 dark:bg-slate-950 min-h-screen flex flex-col">
<%- include('../partials/header') %>
<main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
  <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6">
    <a href="/" class="hover:text-indigo-600 transition-colors"><%= tc.back %></a>
    <span>/</span>
    <span class="text-slate-600 dark:text-slate-300"><%= tl.title %></span>
  </nav>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1"><%= tl.title %></h1>
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= tl.subtitle %></p>
  </div>
  <%- include('../partials/ads', { adType: 'banner728' }) %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.input %></h2>
        <div class="flex items-center gap-2">
          <label class="text-xs text-slate-500" for="urlSafe"><%= tl.urlSafe %></label>
          <input type="checkbox" id="urlSafe" class="accent-indigo-600 cursor-pointer">
        </div>
      </div>
      <textarea id="inputText" class="textarea-field min-h-[160px]" placeholder="<%= tl.inputPlaceholder %>"></textarea>
      <div class="flex gap-2 flex-wrap">
        <button id="btnEncode" class="btn-primary"><%= tc.encode %></button>
        <button id="btnDecode" class="btn-secondary"><%= tc.decode %></button>
        <button id="btnClear" class="btn-secondary ml-auto"><%= tc.clear %></button>
      </div>
    </div>
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.output %></h2>
        <button id="btnCopyOutput" class="copy-btn"><%= tc.copy %></button>
      </div>
      <textarea id="outputText" class="result-box min-h-[160px]" readonly placeholder="<%= tl.outputPlaceholder %>"></textarea>
      <div id="errorMsg" class="hidden text-xs text-red-500 font-medium"></div>
      <button id="btnSwap" class="btn-secondary text-xs"><%= tc.swapIO %></button>
    </div>
  </div>
  <div class="mt-6 card p-5">
    <h3 class="font-semibold text-sm text-slate-900 dark:text-slate-100 mb-2"><%= tl.about %></h3>
    <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= tl.aboutText %></p>
  </div>
</main>
<%- include('../partials/footer') %>
<script src="/js/app.js"></script>
<script src="/js/modules/base64.js"></script>
</body>
</html>
