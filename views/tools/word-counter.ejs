<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <nav class="flex items-center gap-2 text-xs text-muted mb-6">
    <a href="/" class="hover:text-secondary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <span class="text-secondary">Word Counter</span>
  </nav>
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="font-display text-2xl sm:text-3xl font-bold text-primary">Word & Character Counter</h1>
      <span class="badge tag-text">Text</span>
    </div>
    <p class="text-secondary text-sm">Hitung kata, karakter, kalimat, paragraf & estimasi waktu baca secara real-time.</p>
  </div>
  <%- include('../partials/ad', { type: 'banner728' }) %>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-4">
    <% const stats = [['words', 'Kata'], ['chars', 'Karakter'], ['chars-no-space', 'Karakter (no spasi)'], ['sentences', 'Kalimat'], ['paragraphs', 'Paragraf'], ['read-time', 'Baca (menit)']] %>
    <% stats.forEach(([id, label]) => { %>
    <div class="stat-card">
      <div class="text-xs text-muted"><%= label %></div>
      <div id="stat-<%= id %>" class="font-display text-2xl font-bold text-accent">0</div>
    </div>
    <% }) %>
  </div>

  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <label class="label mb-0">Teks</label>
      <button id="btn-clear" class="btn-ghost text-xs py-1 px-2">Clear</button>
    </div>
    <textarea id="text-input" class="textarea-base h-72" placeholder="Ketik atau paste teks di sini...&#10;&#10;Statistik akan otomatis terupdate setiap kamu mengetik."></textarea>
    <div class="flex items-center justify-between mt-3 text-xs text-muted">
      <span>Kecepatan baca diasumsikan 200 kata/menit</span>
      <span id="char-limit-info"></span>
    </div>
  </div>

  <section class="mt-10 pt-8 border-t border-border">
    <h2 class="section-title mb-4 text-base">Tools Lainnya</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% tools.filter(t => t.id !== 'word-counter').slice(0, 8).forEach(t => { %>
      <a href="<%= t.route %>" class="card-tool group text-left">
        <div class="text-xs font-semibold text-primary mb-1 group-hover:text-accent transition-colors"><%= t.name %></div>
        <div class="text-[11px] text-muted line-clamp-2"><%= t.description %></div>
      </a>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/tools/text.js" defer></script>
