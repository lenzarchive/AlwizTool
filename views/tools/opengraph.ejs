<% var tl = t.tools.opengraph; var tc = t.common; %>
  <div class="card p-5 mb-6 space-y-3">
    <div class="flex gap-2">
      <input type="url" id="urlInput" class="input-field flex-1" placeholder="<%= tl.urlPlaceholder %>" autocomplete="off">
      <button id="btnCheck" class="btn-primary shrink-0"><%= tl.checkBtn %></button>
    </div>
    <p class="text-xs text-slate-400"><%= tl.urlHint %></p>
    <div id="errorMsg" class="hidden text-sm text-red-500 font-medium flex items-center gap-2">
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01"/></svg>
      <span id="errorText"></span>
    </div>
  </div>
  <div id="loadingState" class="hidden text-center py-12 text-slate-400">
    <svg class="w-7 h-7 animate-spin mx-auto mb-3 text-indigo-500" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
    </svg>
    <p class="text-sm"><%= tl.fetching %></p>
  </div>
  <div id="results" class="hidden space-y-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="card p-5 space-y-3">
        <h2 class="font-semibold text-sm text-slate-900 dark:text-slate-100 flex items-center gap-2">
          <span class="badge bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400">og:</span>
          <%= tl.ogPreview %>
        </h2>
        <div class="border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden bg-white dark:bg-slate-900">
          <div id="ogImage" class="w-full aspect-[1.91/1] bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 text-xs overflow-hidden"></div>
          <div class="p-3 space-y-1">
            <p id="ogSite" class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"></p>
            <p id="ogTitle" class="font-semibold text-sm text-slate-900 dark:text-slate-100 leading-snug line-clamp-2"></p>
            <p id="ogDesc" class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 leading-relaxed"></p>
          </div>
        </div>
      </div>
      <div class="card p-5 space-y-3">
        <h2 class="font-semibold text-sm text-slate-900 dark:text-slate-100 flex items-center gap-2">
          <span class="badge bg-sky-100 dark:bg-sky-900/40 text-sky-600 dark:text-sky-400">twitter:</span>
          <%= tl.twitterPreview %>
        </h2>
        <div class="border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden bg-white dark:bg-slate-900">
          <div id="twImage" class="w-full aspect-[1.91/1] bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 text-xs overflow-hidden"></div>
          <div class="p-3 space-y-1">
            <p id="twCard" class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"></p>
            <p id="twTitle" class="font-semibold text-sm text-slate-900 dark:text-slate-100 leading-snug line-clamp-2"></p>
            <p id="twDesc" class="text-xs text-slate-500 dark:text-slate-400 line-clamp-2 leading-relaxed"></p>
          </div>
        </div>
      </div>
    </div>
    <div id="infoBar" class="card p-4 flex flex-wrap gap-4 text-xs"></div>
    <div class="card p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-sm text-slate-900 dark:text-slate-100"><%= tl.metaTags %></h2>
        <button id="btnCopyMeta" class="copy-btn hidden"><%= tc.copyAll %></button>
      </div>
      <div id="metaTable" class="divide-y divide-slate-100 dark:divide-slate-800"></div>
    </div>
  </div>
<script>var I18N = {
  noImage: "<%= tl.noImage %>",
  cardType: "<%= tl.cardType %>",
  copied: "<%= tc.copied %>"
};
</script>
<script src="/js/app.js">
</script>
<script src="/js/modules/opengraph.js">
</script>
