<%- include('../partials/head') %>
<body class="bg-slate-50 dark:bg-slate-950 min-h-screen flex flex-col">
<%- include('../partials/header') %>
<main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
  <nav class="flex items-center gap-2 text-xs text-slate-400 mb-6">
    <a href="/" class="hover:text-indigo-600 transition-colors"><%= t('nav.home') %></a>
    <span>/</span>
    <span class="text-slate-600 dark:text-slate-300"><%= t('page.password.h1') %></span>
  </nav>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-1"><%= t('page.password.h1') %></h1>
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= t('page.password.desc') %></p>
  </div>
  <%- include('../partials/ads', { adType: 'banner728' }) %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-5">
      <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= t('page.password.config') %></h2>
      <div>
        <div class="flex justify-between mb-2">
          <label class="text-sm text-slate-700 dark:text-slate-300 font-medium"><%= t('page.password.length') %> <span id="lengthVal" class="text-indigo-600 font-bold">16</span></label>
        </div>
        <input type="range" id="lengthRange" min="6" max="128" value="16" class="w-full accent-indigo-600">
      </div>
      <div class="space-y-3">
        <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incUppercase" checked class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= t('page.password.uppercase') %></span></label>
        <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incLowercase" checked class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= t('page.password.lowercase') %></span></label>
        <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incNumbers" checked class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= t('page.password.numbers') %></span></label>
        <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incSymbols" class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= t('page.password.symbols') %></span></label>
        <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="excAmbiguous" class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= t('page.password.avoidAmbiguous') %></span></label>
      </div>
      <div>
        <label class="text-sm text-slate-700 dark:text-slate-300 font-medium mb-1.5 block" for="pwCount"><%= t('page.password.count') %></label>
        <input type="number" id="pwCount" value="1" min="1" max="50" class="input-field w-24">
      </div>
      <button id="btnGenerate" class="btn-primary w-full justify-center"><%= t('page.password.generateBtn') %></button>
    </div>
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= t('common.result') %></h2>
        <button id="btnCopyAll" class="copy-btn"><%= t('common.copyAll') %></button>
      </div>
      <div id="passwordList" class="space-y-2"></div>
      <div id="strengthBar" class="hidden mt-2">
        <div class="flex justify-between text-xs text-slate-500 mb-1">
          <span><%= t('page.password.strength') %></span>
          <span id="strengthLabel"></span>
        </div>
        <div class="h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
          <div id="strengthFill" class="h-full rounded-full transition-all duration-300"></div>
        </div>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
<script>var I18N = { pickOne: "<%= t('page.password.pickOne') %>", weak: "<%= t('page.password.weak') %>", medium: "<%= t('page.password.medium') %>", strong: "<%= t('page.password.strong') %>", generateFirst: "<%= t('common.generateFirst') %>", copied: "<%= t('common.copied') %>" };</script>
<script src="/js/app.js"></script>
<script src="/js/modules/password.js"></script>
</body>
</html>
