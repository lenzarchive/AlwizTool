<% var tl = t.tools.password; var tc = t.common; %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-5 space-y-5">
      <div>
        <label class="label"><%= tl.modeLabel %></label>
        <div class="flex gap-2">
          <label class="flex-1 flex items-center justify-center gap-2 cursor-pointer px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-medium transition-colors" id="modeRandomLabel">
            <input type="radio" name="pwMode" value="random" checked class="accent-indigo-600">
            <span><%= tl.modeRandom %></span>
          </label>
          <label class="flex-1 flex items-center justify-center gap-2 cursor-pointer px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-medium transition-colors" id="modePassLabel">
            <input type="radio" name="pwMode" value="passphrase" class="accent-indigo-600">
            <span><%= tl.modePassphrase %></span>
          </label>
        </div>
      </div>
      <div id="randomOptions" class="space-y-4">
        <div>
          <div class="flex justify-between mb-2">
            <label class="text-sm text-slate-700 dark:text-slate-300 font-medium"><%= tl.length %>: <span id="lengthVal" class="text-indigo-600 font-bold">16</span></label>
          </div>
          <input type="range" id="lengthRange" min="4" max="128" value="16" class="w-full accent-indigo-600">
          <div class="flex justify-between text-xs text-slate-400 mt-0.5"><span>4</span><span>64</span><span>128</span></div>
        </div>
        <div class="space-y-2.5">
          <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incUppercase" checked class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= tl.uppercase %></span></label>
          <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incLowercase" checked class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= tl.lowercase %></span></label>
          <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incNumbers" checked class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= tl.numbers %></span></label>
          <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="incSymbols" class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= tl.symbols %></span></label>
          <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="excAmbiguous" class="accent-indigo-600 w-4 h-4"><span class="text-sm text-slate-700 dark:text-slate-300"><%= tl.noAmbiguous %></span></label>
        </div>
      </div>
      <div id="passphraseOptions" class="space-y-4 hidden">
        <div>
          <label class="text-sm text-slate-700 dark:text-slate-300 font-medium mb-2 block"><%= tl.wordCount %>: <span id="wordCountVal" class="text-indigo-600 font-bold">4</span></label>
          <input type="range" id="wordCountRange" min="3" max="8" value="4" class="w-full accent-indigo-600">
          <div class="flex justify-between text-xs text-slate-400 mt-0.5"><span>3</span><span>8</span></div>
        </div>
        <div>
          <label class="label" for="separatorSelect"><%= tl.separator %></label>
          <select id="separatorSelect" class="select-field w-full">
            <option value="-"><%= tl.sepHyphen %></option>
            <option value="."><%= tl.sepDot %></option>
            <option value=" "><%= tl.sepSpace %></option>
            <option value=""><%= tl.sepNone %></option>
          </select>
        </div>
      </div>
      <div>
        <label class="text-sm text-slate-700 dark:text-slate-300 font-medium mb-1.5 block" for="pwCount"><%= tl.countLabel %></label>
        <input type="number" id="pwCount" value="5" min="1" max="50" class="input-field w-24">
      </div>
      <button id="btnGenerate" class="btn-primary w-full justify-center"><%= tl.generateBtn %></button>
    </div>
    <div class="card p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-slate-900 dark:text-slate-100 text-sm"><%= tc.result %></h2>
        <button id="btnCopyAll" class="copy-btn"><%= tc.copyAll %></button>
      </div>
      <div id="passwordList" class="space-y-2"></div>
      <div id="strengthBar" class="hidden pt-2 border-t border-slate-100 dark:border-slate-800">
        <div class="flex justify-between text-xs text-slate-500 mb-1.5">
          <span><%= tl.strength %></span>
          <span id="strengthLabel" class="font-semibold"></span>
        </div>
        <div class="h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
          <div id="strengthFill" class="h-full rounded-full transition-all duration-500"></div>
        </div>
      </div>
    </div>
  </div>
<script nonce="<%= nonce %>">var I18N = {
  pickOne: "<%= tl.pickOne %>",
  weak: "<%= tl.weak %>",
  medium: "<%= tl.medium %>",
  strong: "<%= tl.strong %>",
  generateFirst: "<%= tc.generateFirst %>",
  copied: "<%= tc.copied %>"
};
</script>
<script nonce="<%= nonce %>" src="/js/app.js">
</script>
<script nonce="<%= nonce %>" src="/js/modules/password.js">
</script>
