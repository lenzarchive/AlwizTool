<%- include('../partials/head') %>
<%- include('../partials/header') %>
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <nav class="flex items-center gap-2 text-xs text-muted mb-6">
    <a href="/" class="hover:text-secondary transition-colors">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    <span class="text-secondary">HTML Entities</span>
  </nav>
  <div class="mb-6">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="font-display text-2xl sm:text-3xl font-bold text-primary">HTML Entities Encode/Decode</h1>
      <span class="badge tag-encoding">Encoding</span>
    </div>
    <p class="text-secondary text-sm">Encode & decode HTML special characters seperti &amp;, &lt;, &gt;, &quot;, dan lainnya.</p>
  </div>
  <%- include('../partials/ad', { type: 'banner728' }) %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card space-y-3">
      <label class="label">Input</label>
      <textarea id="html-input" class="textarea-base h-52" placeholder="Masukkan teks atau HTML..."></textarea>
      <div class="flex gap-2">
        <button id="btn-encode" class="btn-primary flex-1">Encode HTML</button>
        <button id="btn-decode" class="btn-secondary flex-1">Decode HTML</button>
        <button id="btn-clear" class="btn-ghost">Clear</button>
      </div>
    </div>
    <div class="card space-y-3">
      <div class="flex items-center justify-between">
        <label class="label">Output</label>
        <button id="btn-copy" class="btn-ghost text-xs py-1 px-2">Copy</button>
      </div>
      <textarea id="html-output" class="textarea-base h-52" readonly placeholder="Hasil..."></textarea>
    </div>
  </div>
  <section class="mt-10 pt-8 border-t border-border">
    <h2 class="section-title mb-4 text-base">Tools Lainnya</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      <% tools.filter(t => t.id !== 'html-entities').slice(0, 8).forEach(t => { %>
      <a href="<%= t.route %>" class="card-tool group text-left">
        <div class="text-xs font-semibold text-primary mb-1 group-hover:text-accent transition-colors"><%= t.name %></div>
        <div class="text-[11px] text-muted line-clamp-2"><%= t.description %></div>
      </a>
      <% }) %>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/tools/converters.js" defer></script>
